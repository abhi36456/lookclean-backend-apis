datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  Int              @id @default(autoincrement())
  email               String           @unique
  password            String           @default("")
  name                String           @default("")
  role                String           // "client" | "provider" | "admin"
  providerType        String?          // "freelancer" | "salon"
  phoneNumber         String?          @unique
  isPhoneVerified     Boolean          @default(false)
  onboardingCompleted Boolean          @default(false)
  socialKey           String?          @unique
  socialType          String?          // "google" | "ios"
  createdAt           DateTime         @default(now())
  providerProfile     ProviderProfile?
  clientProfile       ClientProfile?
  bookingsAsClient    Booking[]                 @relation("ClientBookings")
  bookingsAsProvider  Booking[]                 @relation("ProviderBookings")
  availabilityConfig  ProviderAvailabilityConfig?
  activeSlots         ProviderActiveSlot[]

  @@map("users")
}

model ClientProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location        String?
  profileImageUrl String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())

  @@map("client_profile")
}

model ProviderProfile {
  id              Int               @id @default(autoincrement())
  userId          Int               @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  location        String
  profileImageUrl String?
  latitude        Float?
  longitude       Float?
  categories      String?           // JSON string array of categories, e.g. '["Hair", "Nails"]'
  experience      Int               @default(0)
  licenseType     String?
  certificateUrl  String?
  coverImageUrl   String?
  services        ProviderService[]
  amenities       ProviderAmenity[]
  createdAt       DateTime          @default(now())

  @@map("provider_profile")
}

model ProviderService {
  id          Int             @id @default(autoincrement())
  profileId   Int
  profile     ProviderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  price       Int
  category    String
  createdAt   DateTime         @default(now())
  bookingServices BookingService[]

  @@map("provider_service")
}

model ProviderAmenity {
  id          Int             @id @default(autoincrement())
  profileId   Int
  profile     ProviderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  type        String?         @default("amenity") // "amenity" or "ambience"
  icon        String?         @db.VarChar(255)
  createdAt   DateTime        @default(now())

  @@map("provider_amenity")
}

model SystemSetting {
  key   String @id
  value String @db.Text

  @@map("setting_system")
}

model CategorySetting {
  id        Int              @id @default(autoincrement())
  title     String           @unique @db.VarChar(100)
  services  ServiceSetting[]
  createdAt DateTime         @default(now())

  @@map("setting_category")
}

model ServiceSetting {
  id         Int             @id @default(autoincrement())
  mainTypeId Int
  mainType   CategorySetting @relation(fields: [mainTypeId], references: [id], onDelete: Cascade)
  title      String          @db.VarChar(100)
  createdAt  DateTime        @default(now())

  @@unique([mainTypeId, title])
  @@map("setting_service")
}

model AmbienceGroupSetting {
  id        Int               @id @default(autoincrement())
  title     String            @unique @db.VarChar(100)
  items     AmbienceSetting[]
  createdAt DateTime          @default(now())

  @@map("setting_ambience_group")
}

model AmbienceSetting {
  id              Int                  @id @default(autoincrement())
  ambienceGroupId Int
  ambienceGroup   AmbienceGroupSetting @relation(fields: [ambienceGroupId], references: [id], onDelete: Cascade)
  title           String               @db.VarChar(100)
  icon            String?              @db.VarChar(255)
  createdAt       DateTime             @default(now())

  @@unique([ambienceGroupId, title])
  @@map("setting_ambience")
}

model Booking {
  id              Int              @id @default(autoincrement())
  clientId        Int
  client          User             @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  providerId      Int
  provider        User             @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)
  numberOfPeople  Int              @default(1)
  date            DateTime
  timeSlot        String           @db.VarChar(20)
  status          String           @default("pending") // "pending", "confirmed", "completed", "cancelled"
  tipAmount       Float            @default(0)
  tipPercentage   Float?
  voucherCode     String?          @db.VarChar(50)
  voucherDiscount Float            @default(0)
  serviceAmount   Float
  grandTotal      Float
  createdAt       DateTime         @default(now())
  services        BookingService[]

  @@map("bookings")
}

model BookingService {
  id        Int             @id @default(autoincrement())
  bookingId Int
  booking   Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId Int
  service   ProviderService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("booking_services")
}

model ProviderAvailabilityConfig {
  id           Int      @id @default(autoincrement())
  providerId   Int      @unique
  provider     User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  startTime    String   @default("09:00 AM") @db.VarChar(20)
  endTime      String   @default("06:00 PM") @db.VarChar(20)
  slotDuration Int      @default(60) // in minutes
  createdAt    DateTime @default(now())

  @@map("provider_availability_config")
}

model ProviderActiveSlot {
  id          Int      @id @default(autoincrement())
  providerId  Int
  provider    User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dayOfWeek   String   @db.VarChar(20) // "Monday", "Tuesday", ..., "Sunday"
  timeSlot    String   @db.VarChar(20) // "09:00 AM", "10:00 AM", etc.
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([providerId, dayOfWeek, timeSlot])
  @@map("provider_active_slots")
}

model Voucher {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  title     String
  amount    Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("vouchers")
}
